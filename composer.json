{
    "name": "webfiori/queue",
    "description": "A lightweight job queue library for PHP with file-based storage.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ibrahim BinAlshikh",
            "email": "ibrahim@webfiori.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "WebFiori\\Queue\\": "WebFiori/Queue/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebFiori\\Queue\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "scripts": {
        "test": "phpunit --configuration tests/phpunit.xml",
        "fix-cs": "php-cs-fixer fix --config=php_cs.php.dist"
    }
}
